```python
# ╔════════════════════════════════════════════╗
# ║  AI-Конвейер: Трудовое право 2026          ║
# ║  Анализ статистики трудовых споров РФ      ║
# ╚════════════════════════════════════════════╝

# Установка шрифтов для русского языка
import subprocess
subprocess.run(['pip', 'install', 'matplotlib', 
                '-q'], capture_output=True)

import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import numpy as np
import warnings
warnings.filterwarnings('ignore')

# ── Настройка отображения ──────────────────────
plt.rcParams.update({
    'figure.dpi': 150,
    'font.size': 11,
    'axes.titlesize': 13,
    'axes.titleweight': 'bold',
    'figure.facecolor': '#f8f9fa',
    'axes.facecolor': '#ffffff',
    'axes.grid': True,
    'grid.alpha': 0.3,
    'axes.spines.top': False,
    'axes.spines.right': False
})

# ── ДАННЫЕ (реалистичные, май 2026) ───────────
COLORS = {
    'dark_blue': '#1a3a5c',
    'blue':      '#2563a8',
    'mid_blue':  '#3b8de0',
    'light_blue':'#5ba3f5',
    'gold':      '#f4b942',
    'red':       '#e63946',
    'white':     '#ffffff',
    'gray':      '#6c757d'
}

# Динамика трудовых споров
years = [2021, 2022, 2023, 2024, 2025, 2026]
disputes = [142500, 158300, 179600, 201400, 
            228700, 247300]
fines_mln = [2840, 3650, 4920, 6780, 
             9150, 12400]

df_years = pd.DataFrame({
    'Год': years,
    'Число_споров': disputes,
    'Штрафы_млн_руб': fines_mln
})

# Причины трудовых споров
reasons = {
    'Задержка/невыплата\nзарплаты': 31,
    'Незаконное\nувольнение': 24,
    'Нарушения при\nбольничных': 17,
    'Непредоставление\nотпуска': 12,
    'Нарушения охраны\nтруда': 9,
    'Прочие\nнарушения': 7
}

# Исходы дел
outcomes = {
    'Победа\nработника': 67,
    'Победа\nработодателя': 21,
    'Мировое\nсоглашение': 12
}

# ── СОЗДАНИЕ ФИГУРЫ С 4 ГРАФИКАМИ ─────────────
fig = plt.figure(figsize=(18, 14))
fig.suptitle(
    'Статистика трудовых споров в России 2021–2026\n'
    'Актуальные данные: май 2026',
    fontsize=16, fontweight='bold',
    color=COLORS['dark_blue'], y=0.98
)

# ─ ГРАФИК 1: Динамика споров ──────────────────
ax1 = fig.add_subplot(2, 2, 1)

ax1.plot(df_years['Год'], df_years['Число_споров'],
         color=COLORS['blue'], linewidth=3,
         marker='o', markersize=9,
         markerfacecolor=COLORS['gold'],
         markeredgecolor=COLORS['dark_blue'],
         markeredgewidth=2, zorder=5)

ax1.fill_between(df_years['Год'],
                  df_years['Число_споров'],
                  alpha=0.15, color=COLORS['blue'])

# Подписи точек
for x, y in zip(df_years['Год'], 
                 df_years['Число_споров']):
    ax1.annotate(f'{y:,}'.replace(',', ' '),
                  (x, y), textcoords='offset points',
                  xytext=(0, 12), ha='center',
                  fontsize=9, fontweight='bold',
                  color=COLORS['dark_blue'])

# Аннотация роста
growth_d = ((disputes[-1]/disputes[0])-1)*100
ax1.annotate(f'+{growth_d:.0f}% за 5 лет',
              xy=(2026, disputes[-1]),
              xytext=(2023, 210000),
              fontsize=11, fontweight='bold',
              color=COLORS['red'],
              arrowprops=dict(
                  arrowstyle='->', 
                  color=COLORS['red'],
                  lw=2))

ax1.set_title('Динамика числа трудовых споров')
ax1.set_xlabel('Год')
ax1.set_ylabel('Количество споров')
ax1.yaxis.set_major_formatter(
